        {
          "name": "verify-2fa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "// guardar token en una variable de coleccion\r",
                  "pm.collectionVariables.set(\"auth_token\", response.data.access_token);\r",
                  "\r",
                  "// opcional: mostrar por consola\r",
                  "console.log(\"Token guardado:\", response.data.access_token);"
                ],
                "type": "text/javascript",
                "packages": {},
